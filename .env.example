# Proxy Configuration
# "vercel" - Uses /api/* routes (works locally via Vite proxy, and on Vercel via serverless functions)
# "cloudflare" - Uses yf.tigzig.com directly (no proxy needed)
VITE_PROXY_MODE=vercel

# QPulse Backend API Key (used by Vercel serverless proxy)
QPULSE_API_KEY=your-api-key-here
